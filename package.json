{
  "name": "geodraw",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "npm run test:command",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "check:handoff": "node scripts/check-handoff-update.mjs",
    "test:command": "node --import tsx src/scene/__tests__/command-parser.test.ts && node --import tsx src/scene/__tests__/command-redefine.test.ts && node --import tsx src/scene/__tests__/command-redefine-export.test.ts",
    "test:export": "node scripts/test-export.mjs",
    "test:perf": "tsx src/scene/__tests__/eval-perf.test.ts",
    "test:zoom": "node --import tsx scripts/zoom-stress.ts",
    "test:scene": "tsx src/scene/__tests__/intersection-ownership-regression.test.ts && tsx src/scene/__tests__/polygon-ownership-stress.test.ts && tsx src/scene/__tests__/tangent-circle-circle.test.ts",
    "diag:scene": "tsx scripts/scene-diagnostics.ts",
    "test:export:watch": "tsx --watch src/export/__tests__/line-extents.test.ts",
    "update:tkz-macros": "tsx scripts/extract-tkz-euclide-macros.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "katex": "^0.16.28",
    "lucide-react": "^0.563.0",
    "mathjs": "^13.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
